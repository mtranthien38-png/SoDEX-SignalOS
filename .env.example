# SoSoValue API
# Get it from https://sosovalue.com/developer/dashboard
# Do not commit your real key. Your screenshot shows a Demo Plan with 10,000 monthly calls and 10 req/min.
SOSOVALUE_API_KEY=SOSO_your_key_here
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com/openapi/v1

# SoDEX API / network
# Testnet endpoints from the SoDEX API docs.
SODEX_NETWORK=testnet
SODEX_SPOT_BASE_URL=https://testnet-gw.sodex.dev/api/v1/spot
SODEX_PERPS_BASE_URL=https://testnet-gw.sodex.dev/api/v1/perps

# X-API-Key must be the API KEY NAME, not the public key/private key.
SODEX_API_KEY_NAME=SODEX_API_KEY
SODEX_API_PUBLIC_KEY=0xYourRegisteredApiPublicKey
SODEX_API_PRIVATE_KEY=
SODEX_ACCOUNT_ID=
SODEX_USER_ADDRESS=0xYourWalletAddress

# Keep false for judging/demo. This build can create EIP-712 signing material but intentionally blocks actual live HTTP order submission.
SODEX_LIVE_TRADING=false

# Optional AI provider for generated narrative. If empty, local rule-based scoring is used.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Development
PORT=8787
MOCK_MODE=false
